<Window x:Class="InterficieSpotify.AssignPermisos"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:InterficieSpotify"
        mc:Ignorable="d"
        Title="Assigna Permisos"
        Height="550"
        Width="900"
        WindowStartupLocation="CenterScreen"
        Background="#121212">

    <Grid>
        
        <!-- Botón volver -->
        <Button x:Name="Enrrere"
        Content="←"
        HorizontalAlignment="Left"
        VerticalAlignment="Top"
        Margin="15"
        Width="40"
        Height="40"
        FontSize="18"
        Background="#1E1E1E"
        Foreground="White"
        BorderThickness="0"
        Click="Enrrere_Click"/>

        <!-- Tarjeta central -->
        <Border Width="820"
                Height="450"
                Background="#1E1E1E"
                CornerRadius="12"
                Padding="20"
                HorizontalAlignment="Center"
                VerticalAlignment="Center">

            <Grid>

                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>

                <!-- Cabecera -->
                <DockPanel Margin="0,0,0,15">

                    <TextBlock Text="Assignar Permisos"
                               FontSize="24"
                               FontWeight="Bold"
                               Foreground="White"
                               DockPanel.Dock="Left"/>

                    <StackPanel Orientation="Horizontal"
                                DockPanel.Dock="Right">

                        <TextBlock Text="Selecciona Rol:"
                                   VerticalAlignment="Center"
                                   Foreground="White"
                                   FontSize="14"
                                   Margin="0,0,10,0"/>

                        <ComboBox x:Name="cbRoles"
                                  Width="200"
                                  Height="30"
                                  FontSize="14"
                                  Background="#2A2A2A"
                                  Foreground="White"
                                  BorderBrush="#404040"/>

                    </StackPanel>

                </DockPanel>

                <!-- DataGrid -->
                <DataGrid x:Name="dgPermisos"
                          Grid.Row="1"
                          AutoGenerateColumns="False"
                          CanUserAddRows="False"
                          Background="#2A2A2A"
                          Foreground="White"
                          BorderBrush="#404040"
                          RowBackground="#2A2A2A"
                          AlternatingRowBackground="#333333">

                    <DataGrid.Columns>

                        <DataGridTextColumn Header="Permís"
                                            Binding="{Binding Nom}"
                                            Width="*"/>

                        <DataGridCheckBoxColumn Header="Assignat"
                                                Binding="{Binding Assignat}"
                                                Width="120"/>

                    </DataGrid.Columns>

                </DataGrid>

                <!-- Botón guardar -->
                <Button x:Name="btnGuardar"
                        Content="Guardar"
                        Grid.Row="2"
                        Width="150"
                        Height="40"
                        FontSize="16"
                        HorizontalAlignment="Right"
                        Margin="0,15,0,0"
                        Background="#1DB954"
                        Foreground="White"
                        BorderThickness="0"
                        Click="btnGuardar_Click"/>

            </Grid>

        </Border>

    </Grid>
</Window>