<Window x:Class="InterficieSpotify.PlayLists"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:InterficieSpotify"
        mc:Ignorable="d"
        Title="PlayLists"
        Height="450"
        Width="800"
        WindowStartupLocation="CenterScreen"
        Background="#121212">

    <Grid>

        <!-- Botón volver -->
        <Button x:Name="Enrrere"
                Content="←"
                HorizontalAlignment="Left"
                VerticalAlignment="Top"
                Margin="15"
                Width="40"
                Height="40"
                FontSize="18"
                Background="#1E1E1E"
                Foreground="White"
                BorderThickness="0"
                Click="Enrrere_Click"/>

        <!-- Card central -->
        <Border Width="720"
                Height="340"
                Background="#1E1E1E"
                CornerRadius="12"
                Padding="20"
                HorizontalAlignment="Center"
                VerticalAlignment="Center">

            <Grid>

                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition/>
                </Grid.RowDefinitions>

                <!-- Cabecera -->
                <DockPanel Margin="0,0,0,15">

                    <TextBlock Text="PlayLists"
                               FontSize="24"
                               FontWeight="Bold"
                               Foreground="White"
                               DockPanel.Dock="Left"/>

                    <Button x:Name="CarregarDades"
                            Content="Carregar Dades"
                            Width="150"
                            Height="35"
                            FontSize="14"
                            Background="#1DB954"
                            Foreground="White"
                            BorderThickness="0"
                            HorizontalAlignment="Right"
                            Click="CarregarDades_Click"/>
                </DockPanel>

                <!-- Tabla -->
                <DataGrid x:Name="dgPlayLists"
                          Grid.Row="1"
                          AutoGenerateColumns="True"
                          IsReadOnly="True"
                          Background="#2A2A2A"
                          Foreground="White"
                          BorderBrush="#404040"
                          RowBackground="#2A2A2A"
                          AlternatingRowBackground="#333333"
                          SelectionChanged="dgPlayLists_SelectionChanged"/>

            </Grid>

        </Border>

    </Grid>
</Window>