<Window x:Class="InterficieSpotify.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:InterficieSpotify"
        mc:Ignorable="d"
        Title="Spotify Admin"
        Height="450"
        Width="800"
        WindowStartupLocation="CenterScreen"
        Background="#121212">

    <Grid>

        <!-- PANEL CENTRAL -->
        <Border Width="500"
                Height="260"
                Background="#1E1E1E"
                CornerRadius="12"
                Padding="30"
                HorizontalAlignment="Center"
                VerticalAlignment="Center">

            <StackPanel>

                <!-- TITULO -->
                <TextBlock Text="Pantalla d'Administració"
                           FontSize="26"
                           Foreground="White"
                           FontWeight="Bold"
                           HorizontalAlignment="Center"
                           Margin="0,0,0,25"/>

                <TextBlock Text="Amb quina taula vols treballar?"
                           FontSize="16"
                           Foreground="#B3B3B3"
                           HorizontalAlignment="Center"
                           Margin="0,0,0,30"/>

                <!-- BOTONES -->
                <StackPanel Orientation="Horizontal"
                            HorizontalAlignment="Center"
                            Margin="0,10,0,0">

                    <Button x:Name="Cancons"
                            Content="Songs"
                            Width="130"
                            Height="45"
                            FontSize="15"
                            Background="#1DB954"
                            Foreground="White"
                            BorderThickness="0"
                            Margin="10"
                            Click="Button_Click_1"/>

                    <Button Content="Users"
                            Width="130"
                            Height="45"
                            FontSize="15"
                            Background="#1DB954"
                            Foreground="White"
                            BorderThickness="0"
                            Margin="10"
                            Click="Button_Click"/>

                    <Button Content="Assignar Permís"
                            Width="130"
                            Height="45"
                            FontSize="15"
                            Background="#1DB954"
                            Foreground="White"
                            BorderThickness="0"
                            Margin="10"
                            Click="Button_Click_2"/>

                </StackPanel>

            </StackPanel>

        </Border>

    </Grid>
</Window>