<Window x:Class="InterficieSpotify.Songs"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:InterficieSpotify"
        mc:Ignorable="d"
        Title="Songs"
        Height="500"
        Width="900"
        WindowStartupLocation="CenterScreen"
        Background="#121212">

    <Grid>

        <!-- Botón volver -->
        <Button x:Name="Enrrere"
                Content="←"
                HorizontalAlignment="Left"
                VerticalAlignment="Top"
                Margin="15"
                Width="40"
                Height="40"
                FontSize="18"
                Background="#1E1E1E"
                Foreground="White"
                BorderThickness="0"
                Click="Enrrere_Click"/>

        <!-- Card central -->
        <Border Width="820"
                Height="400"
                Background="#1E1E1E"
                CornerRadius="12"
                Padding="20"
                HorizontalAlignment="Center"
                VerticalAlignment="Center">

            <Grid>

                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition/>
                </Grid.RowDefinitions>

                <!-- Cabecera -->
                <DockPanel Margin="0,0,0,15">

                    <TextBlock Text="Songs"
                               FontSize="24"
                               FontWeight="Bold"
                               Foreground="White"
                               DockPanel.Dock="Left"/>

                    <StackPanel Orientation="Horizontal" DockPanel.Dock="Right">

                        <Button x:Name="CarregarDades"
                                Content="Obtenir Totes"
                                Click="CarregarDades_Click"
                                Width="130"
                                Height="35"
                                FontSize="14"
                                Background="#1DB954"
                                Foreground="White"
                                BorderThickness="0"
                                Margin="5"/>

                        <Button x:Name="Post"
                                Content="Afegir Cançó"
                                Click="AfegirCancoDesdeGrid"
                                Width="130"
                                Height="35"
                                FontSize="14"
                                Background="#1DB954"
                                Foreground="White"
                                BorderThickness="0"
                                Margin="5"/>

                    </StackPanel>

                </DockPanel>

                <!-- DataGrid -->
                <DataGrid x:Name="dgSongs"
                          Grid.Row="1"
                          AutoGenerateColumns="False"
                          CanUserAddRows="False"
                          CanUserDeleteRows="False"
                          CanUserSortColumns="True"
                          Background="#2A2A2A"
                          Foreground="White"
                          BorderBrush="#404040"
                          RowBackground="#2A2A2A"
                          AlternatingRowBackground="#333333">

                    <DataGrid.Columns>

                        <DataGridTextColumn Header="ID"
                                            Binding="{Binding Id, Mode=OneWay}"
                                            IsReadOnly="True"
                                            Width="*"/>

                        <DataGridTextColumn Header="Títol"
                                            Binding="{Binding Titol, UpdateSourceTrigger=PropertyChanged}"
                                            Width="*"/>

                        <DataGridTextColumn Header="Artista"
                                            Binding="{Binding Artista, UpdateSourceTrigger=PropertyChanged}"
                                            Width="*"/>

                        <DataGridTextColumn Header="Àlbum"
                                            Binding="{Binding Album, UpdateSourceTrigger=PropertyChanged}"
                                            Width="*"/>

                        <DataGridTextColumn Header="Durada"
                                            Binding="{Binding Durada, UpdateSourceTrigger=PropertyChanged}"
                                            Width="*"/>

                        <DataGridTemplateColumn Header="Accions" Width="140">
                            <DataGridTemplateColumn.CellTemplate>

                                <DataTemplate>
                                    <StackPanel Orientation="Horizontal">

                                        <Button Content="Desar"
                                                Click="GuardarCancoDesdeGrid"
                                                Margin="3"
                                                Padding="5"
                                                Background="#1DB954"
                                                Foreground="White"
                                                FontSize="10"/>

                                        <Button x:Name="btnEliminar"
                                                Content="Eliminar"
                                                Click="EliminarCancoDesdeGrid"
                                                Margin="3"
                                                Padding="5"
                                                Background="#E74C3C"
                                                Foreground="White"
                                                FontSize="10"/>

                                    </StackPanel>
                                </DataTemplate>

                            </DataGridTemplateColumn.CellTemplate>
                        </DataGridTemplateColumn>

                    </DataGrid.Columns>

                </DataGrid>

            </Grid>

        </Border>

    </Grid>
</Window>