<Window x:Class="InterficieSpotify.LogIn"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:InterficieSpotify"
        mc:Ignorable="d"
        Title="Login"
        Height="450"
        Width="800"
        WindowStartupLocation="CenterScreen"
        Background="#121212">

    <Grid>

        <!-- Tarjeta central -->
        <Border Width="320"
                Height="300"
                Background="#1E1E1E"
                CornerRadius="10"
                Padding="25"
                HorizontalAlignment="Center"
                VerticalAlignment="Center">

            <StackPanel>

                <!-- Título -->
                <TextBlock Text="Iniciar Sesión"
                           FontSize="26"
                           Foreground="White"
                           FontWeight="Bold"
                           HorizontalAlignment="Center"
                           Margin="0,0,0,25"/>

                <!-- Usuario -->
                <TextBlock Text="Usuario"
                           Foreground="White"
                           Margin="0,0,0,5"/>

                <TextBox x:Name="username"
                         Height="40"
                         FontSize="16"
                         Background="#2A2A2A"
                         Foreground="White"
                         BorderBrush="#444"
                         Padding="10"
                         Margin="0,0,0,15"/>

                <!-- Contraseña -->
                <TextBlock Text="Contraseña"
                           Foreground="White"
                           Margin="0,0,0,5"/>

                <PasswordBox x:Name="password"
                             Height="40"
                             FontSize="16"
                             Background="#2A2A2A"
                             Foreground="White"
                             BorderBrush="#444"
                             Padding="10"
                             Margin="0,0,0,20"/>

                <!-- Botón -->
                <Button x:Name="entrar"
                        Content="Entrar"
                        Height="40"
                        FontSize="16"
                        Background="#1DB954"
                        Foreground="White"
                        BorderThickness="0"
                        Click="Button_Click"/>

            </StackPanel>

        </Border>

    </Grid>
</Window>